        local stroke = Utility:CreateStroke(1, Color3.new(1,1,1), 1, kList)
        ThemeManager:Register(stroke, {Color = "BorderLight"})
        Utility:DropShadow(kList, 15, Vector2.new(0,6), 0.6)
        Utility:MakeDraggable(kList, kList)

        local title = Instance.new("TextLabel")
        title.BackgroundTransparency = 1
        title.Position = UDim2.new(0, 12, 0, 0)
        title.Size = UDim2.new(1, -24, 0, 30)
        title.FontFace = Font.new("rbxasset://fonts/families/GothamSSm.json", Enum.FontWeight.Bold)
        title.Text = "Keybinds"
        title.TextSize = 13
        title.TextXAlignment = Enum.TextXAlignment.Left
        title.ZIndex = 51
        title.Parent = kList
        ThemeManager:Register(title, {TextColor3 = "Accent"})

        local container = Instance.new("Frame")
        container.BackgroundTransparency = 1
        container.Position = UDim2.new(0, 0, 0, 30)
        container.Size = UDim2.new(1, 0, 1, -30)
        container.ZIndex = 51
        container.Parent = kList

        local lay = Instance.new("UIListLayout")
        lay.Padding = UDim.new(0, 2)
        lay.SortOrder = Enum.SortOrder.LayoutOrder
        lay.Parent = container

        local pad = Instance.new("UIPadding")
        pad.PaddingBottom = UDim.new(0, 8)
        pad.PaddingLeft = UDim.new(0, 12)
        pad.PaddingRight = UDim.new(0, 12)
        pad.PaddingTop = UDim.new(0, 4)
        pad.Parent = container

        Window.KeybindListFrame = kList
        Window.KeybindContainer = container
        Window.KeybindLayout = lay
    end

    function Window:UpdateKeybinds()
        if not Window.KeybindListFrame then Window:BuildKeybindList() end
        for _, c in pairs(Window.KeybindContainer:GetChildren()) do
            if c:IsA("Frame") then c:Destroy() end
        end

        local count = 0
        if Window.Keybinds then
            for _, kb in pairs(Window.Keybinds) do
                if kb.Value and kb.Keybind.Value ~= Enum.KeyCode.Unknown then
                    count = count + 1
                    local f = Instance.new("Frame")
                    f.BackgroundTransparency = 1
                    f.Size = UDim2.new(1, 0, 0, 18)
                    f.Parent = Window.KeybindContainer
                    
                    local n = Instance.new("TextLabel")
                    n.BackgroundTransparency = 1
                    n.Size = UDim2.new(0.6, 0, 1, 0)
                    n.FontFace = Font.new("rbxasset://fonts/families/GothamSSm.json", Enum.FontWeight.Medium)
                    n.Text = kb.Name
                    n.TextSize = 12
                    n.TextXAlignment = Enum.TextXAlignment.Left
                    n.Parent = f
                    ThemeManager:Register(n, {TextColor3 = "Text2"})

                    local v = Instance.new("TextLabel")
                    v.BackgroundTransparency = 1
                    v.Position = UDim2.new(0.6, 0, 0, 0)
                    v.Size = UDim2.new(0.4, 0, 1, 0)
                    v.FontFace = Font.new("rbxasset://fonts/families/GothamSSm.json", Enum.FontWeight.Bold)
                    v.Text = string.format("[%s]", kb.Keybind.Value.Name)
                    v.TextSize = 11
                    v.TextXAlignment = Enum.TextXAlignment.Right
                    v.Parent = f
                    ThemeManager:Register(v, {TextColor3 = "Accent"})
                end
            end
        end

        if Window.KeybindListState then
            Window.KeybindListFrame.Visible = true
            local targetH = count == 0 and 30 or 30 + 12 + (count * 18) + ((count - 1) * 2)
            Utility:Tween(Window.KeybindListFrame, HihlLib.TweenData.Fast, {Size = UDim2.new(0, 200, 0, targetH)})
        else
            Window.KeybindListFrame.Visible = false
        end
    end

    function Window:ToggleKeybindList(state)
        Window.KeybindListState = state
        Window:UpdateKeybinds()
    end

    function Window:Destroy()
        SG:Destroy()
    end

    return Window
end

return HihlLib
