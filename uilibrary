local SaveManager = {
    Folder = "HihlLib",
    File = "default.json",
    Options = {}, 
    Ignore = {}
}

function SaveManager:SetFolder(name)
    self.Folder = name
    if isfolder and not isfolder(self.Folder) then
        makefolder(self.Folder)
    end
end

function SaveManager:SetFile(name)
    if not name:match("%.json$") then name = name .. ".json" end
    self.File = name
end

function SaveManager:Save()
    if not writefile then return end
    local data = {}
    for name, opt in pairs(self.Options) do
        if not self.Ignore[name] and opt.Type ~= "Button" and opt.Type ~= "Label" then
            data[name] = {Value = opt.Value, Type = opt.Type}
        end
    end
    writefile(self.Folder .. "/" .. self.File, HttpService:JSONEncode(data))
end

function SaveManager:Load()
    if not readfile or not isfile then return end
    local path = self.Folder .. "/" .. self.File
    if not isfile(path) then return end
    local success, encoded = pcall(readfile, path)
    if not success then return end
    local success2, data = pcall(HttpService.JSONDecode, HttpService, encoded)
    if not success2 or type(data) ~= "table" then return end

    for name, saved in pairs(data) do
        local opt = self.Options[name]
        if opt and opt.Type == saved.Type then
            if type(opt.SetValue) == "function" then
                pcall(function() opt:SetValue(saved.Value) end)
            end
        end
    end
end

function SaveManager:Add(name, component)
    if not name then return end
    self.Options[name] = component
end

