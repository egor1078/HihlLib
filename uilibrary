                Utility:CreateCorner(6, searchBox)
                ThemeManager:Register(searchBox, {BackgroundColor3 = "ValueBg", TextColor3 = "Text1", PlaceholderColor3 = "TextDim"})
            end

            local scr = Instance.new("ScrollingFrame")
            scr.BackgroundTransparency = 1
            scr.BorderSizePixel = 0
            scr.Position = UDim2.new(0, 0, 0, msel.Searchable and 30 or 0)
            scr.Size = UDim2.new(1, 0, 1, msel.Searchable and -30 or 0)
            scr.AutomaticCanvasSize = Enum.AutomaticSize.Y
            scr.CanvasSize = UDim2.new(0,0,0,0)
            scr.ScrollBarThickness = isMobile and 3 or 1
            scr.Parent = dropContainer
            ThemeManager:Register(scr, {ScrollBarImageColor3 = "ScrollBar"})

            local list = Instance.new("UIListLayout")
            list.Padding = UDim.new(0, 2)
            list.SortOrder = Enum.SortOrder.LayoutOrder
            list.Parent = scr

            local api = self:AddElement(msel.Flag, "MultiSelect", f)
            local isOpen = false
            local optionBtns = {}

            local function updateDisplay()
                valLbl.Text = #msel.Value > 0 and table.concat(msel.Value, ", ") or "None"
            end

            local function buildOptions()
                for _, b in pairs(optionBtns) do b:Destroy() end
                table.clear(optionBtns)

                local filter = searchBox and string.lower(searchBox.Text) or ""
                
                for _, opt in ipairs(msel.Options) do
                    if filter == "" or string.find(string.lower(opt), filter) then
                        local b = Instance.new("TextButton")
                        b.Size = UDim2.new(1, 0, 0, 24)
                        b.AutoButtonColor = false
                        b.Text = ""
                        b.Parent = scr
                        Utility:CreateCorner(4, b)
                        ThemeManager:Register(b, {BackgroundColor3 = "Bg"})

                        local tl = Instance.new("TextLabel")
                        tl.BackgroundTransparency = 1
                        tl.Position = UDim2.new(0, 8, 0, 0)
                        tl.Size = UDim2.new(1, -36, 1, 0)
                        tl.FontFace = Font.new("rbxasset://fonts/families/GothamSSm.json", Enum.FontWeight.Regular)
                        tl.Text = tostring(opt)
                        tl.TextSize = 12
                        tl.TextXAlignment = Enum.TextXAlignment.Left
                        tl.Parent = b
                        ThemeManager:Register(tl, {TextColor3 = table.find(msel.Value, opt) and "Accent" or "Text2"})

                        local checkBg = Instance.new("Frame")
                        checkBg.AnchorPoint = Vector2.new(1, 0.5)
                        checkBg.Position = UDim2.new(1, -6, 0.5, 0)
                        checkBg.Size = UDim2.new(0, 14, 0, 14)
                        checkBg.Parent = b
                        Utility:CreateCorner(4, checkBg)
                        ThemeManager:Register(checkBg, {BackgroundColor3 = table.find(msel.Value, opt) and "Accent" or "Bg"})
                        local checkStroke = Utility:CreateStroke(1, Color3.new(1,1,1), 0, checkBg)
                        ThemeManager:Register(checkStroke, {Color = "Border"})

                        local checkIcon = Instance.new("ImageLabel")
                        checkIcon.BackgroundTransparency = 1
                        checkIcon.Position = UDim2.new(0, 2, 0, 2)
                        checkIcon.Size = UDim2.new(1, -4, 1, -4)
                        checkIcon.Image = "rbxassetid://10709790948" 
                        checkIcon.ImageColor3 = Color3.new(1,1,1)
                        checkIcon.Visible = table.find(msel.Value, opt) ~= nil
                        checkIcon.Parent = checkBg

                        b.InputBegan:Connect(function(inp)
                            if inp.UserInputType == Enum.UserInputType.MouseMovement then
                                Utility:Tween(b, HihlLib.TweenData.Fast, {BackgroundColor3 = ThemeManager:GetColor("BorderLight")})
                            end
                        end)
                        b.InputEnded:Connect(function(inp)
                            if inp.UserInputType == Enum.UserInputType.MouseMovement then
                                Utility:Tween(b, HihlLib.TweenData.Smooth, {BackgroundColor3 = ThemeManager:GetColor("Bg")})
                            end
                        end)

                        b.MouseButton1Click:Connect(function()
                            local idx = table.find(msel.Value, opt)
                            if idx then
                                table.remove(msel.Value, idx)
                                Utility:Tween(checkBg, HihlLib.TweenData.Fast, {BackgroundColor3 = ThemeManager:GetColor("Bg")})
                                Utility:Tween(tl, HihlLib.TweenData.Fast, {TextColor3 = ThemeManager:GetColor("Text2")})
                                checkIcon.Visible = false
                            else
                                table.insert(msel.Value, opt)
                                Utility:Tween(checkBg, HihlLib.TweenData.Fast, {BackgroundColor3 = ThemeManager:GetColor("Accent")})
                                Utility:Tween(tl, HihlLib.TweenData.Fast, {TextColor3 = ThemeManager:GetColor("Accent")})
                                checkIcon.Visible = true
                            end
                            updateDisplay()
                            task.spawn(msel.Callback, msel.Value)
                        end)

                        table.insert(optionBtns, b)
                    end
                end
            end

            buildOptions()
            
            if searchBox then
                searchBox:GetPropertyChangedSignal("Text"):Connect(buildOptions)
            end

            local function toggleDrop()
                isOpen = not isOpen
                local itemH = math.min(#optionBtns, 5) * 26
                local searchH = msel.Searchable and 30 or 0
                local totalH = isOpen and (40 + searchH + itemH) or 36
                Utility:Tween(f, HihlLib.TweenData.Smooth, {Size = UDim2.new(1, 0, 0, totalH)})
                Utility:Tween(icon, HihlLib.TweenData.Smooth, {Rotation = isOpen and 180 or 0})
            end
            topBtn.MouseButton1Click:Connect(toggleDrop)

            topBtn.InputBegan:Connect(function(i)
                if i.UserInputType == Enum.UserInputType.MouseMovement then
                    Utility:Tween(f, HihlLib.TweenData.Fast, {BackgroundColor3 = ThemeManager:GetColor("CardHover")})
                    Utility:Tween(stroke, HihlLib.TweenData.Fast, {Color = ThemeManager:GetColor("BorderHover")})
                    Utility:Tween(lbl, HihlLib.TweenData.Fast, {TextColor3 = ThemeManager:GetColor("Text1")})
                end
            end)
            topBtn.InputEnded:Connect(function(i)
                if i.UserInputType == Enum.UserInputType.MouseMovement then
                    Utility:Tween(f, HihlLib.TweenData.Smooth, {BackgroundColor3 = ThemeManager:GetColor("Card")})
                    Utility:Tween(stroke, HihlLib.TweenData.Smooth, {Color = ThemeManager:GetColor("Border")})
                    Utility:Tween(lbl, HihlLib.TweenData.Smooth, {TextColor3 = ThemeManager:GetColor("Text2")})
                end
            end)

            if msel.Tooltip then Window:SetTooltip(topBtn, msel.Tooltip) end
            
            function api:Set(v) msel.Value = type(v) == "table" and v or {v}; updateDisplay(); buildOptions(); task.spawn(msel.Callback, msel.Value) end
            function api:Get() return msel.Value end
            function api:Refresh(opts)
                msel.Options = opts
                -- clean up values that don't exist anymore
                for i = #msel.Value, 1, -1 do
                    if not table.find(opts, msel.Value[i]) then
                        table.remove(msel.Value, i)
                    end
                end
                updateDisplay()
                buildOptions()
            end
            
            return api
        end

