			fillGradient().Parent = fill

			local knob = Instance.new("Frame")
			knob.Name = "Knob"
			knob.AnchorPoint = Vector2.new(0.5, 0.5)
			knob.BackgroundColor3 = Theme.Knob
			knob.Position = UDim2.new(initPercent, 0, 0.5, 0)
			knob.Size = UDim2.new(0, 12, 0, 12)
			knob.ZIndex = 15
