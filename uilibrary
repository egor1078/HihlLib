			local trigger = Instance.new("TextButton")
			trigger.Name = "Trigger"
			trigger.AnchorPoint = Vector2.new(0, 0.5)
			trigger.BackgroundTransparency = 1
			trigger.Position = UDim2.new(0, -7, 0.5, 0)
			trigger.Size = UDim2.new(1, 14, 5, 0)
			trigger.ZIndex = 16
			trigger.Text = ""
			trigger.Parent = bar

			hoverEffect(frame, fStroke)

			-- Use RenderStepped for frame-perfect slider tracking
			local sliding = false

			local function updateSlider(inputX)
				if not bar or not bar.Parent then return end
				local barPos = bar.AbsolutePosition.X
				local barSize = bar.AbsoluteSize.X
				if barSize <= 0 then return end
				local p = math.clamp((inputX - barPos) / barSize, 0, 1)
				local rawVal = min + (max - min) * p
				local snapped = math.floor(rawVal / increment + 0.5) * increment
				snapped = math.clamp(snapped, min, max)
				local snapP = (snapped - min) / math.max(max - min, 1)

				fill.Size = UDim2.new(snapP, 0, 1, 0)
				knob.Position = UDim2.new(snapP, 0, 0.5, 0)
				valueLabel.Text = tostring(snapped)
				if snapped ~= currentValue then
					currentValue = snapped
					task.spawn(callback, snapped)
				end
			end

			trigger.MouseButton1Down:Connect(function()
				sliding = true
				tween(knob, Tw.Spring, {Size = UDim2.new(0, 16, 0, 16)})
			end)

			UserInputService.InputEnded:Connect(function(input)
				if (input.UserInputType == Enum.UserInputType.MouseButton1
					or input.UserInputType == Enum.UserInputType.Touch) and sliding then
					sliding = false
					tween(knob, Tw.Spring, {Size = UDim2.new(0, 12, 0, 12)})
				end
			end)

			-- Frame-perfect tracking
			(RunService.RenderStepped or RunService.Heartbeat):Connect(function()
				if not sliding then return end
				local mousePos = UserInputService:GetMouseLocation()
				updateSlider(mousePos.X)
			end)

			local sliderAPI = {}
			function sliderAPI:Set(val)
				val = math.clamp(val, min, max)
				local snapped = math.floor(val / increment + 0.5) * increment
				snapped = math.clamp(snapped, min, max)
				currentValue = snapped
				local p = (snapped - min) / math.max(max - min, 1)
				tween(fill, Tw.Silk, {Size = UDim2.new(p, 0, 1, 0)})
				tween(knob, Tw.Silk, {Position = UDim2.new(p, 0, 0.5, 0)})
				valueLabel.Text = tostring(snapped)
				task.spawn(callback, snapped)
			end
			function sliderAPI:Get() return currentValue end
			return sliderAPI
		end

