                    Utility:Tween(f, HihlLib.TweenData.Smooth, {BackgroundColor3 = ThemeManager:GetColor("Card")})
                    Utility:Tween(stroke, HihlLib.TweenData.Smooth, {Color = ThemeManager:GetColor("Border")})
                end
            end)

            if tgl.Tooltip then Window:SetTooltip(f, tgl.Tooltip) end
            function api:Set(v) setState(v) end
            function api:Get() return tgl.Value end
            return api
        end

        function Tab:CreateSlider(cfg)
            local sldr = {
                Name = cfg.Name or "Slider",
                Flag = cfg.Flag or (cfg.Name or "Slider"),
                Min = cfg.Min or 0,
                Max = cfg.Max or 100,
                Value = cfg.Default or cfg.Min or 0,
                Inc = cfg.Increment or 1,
                Callback = cfg.Callback or function() end,
                Tooltip = cfg.Tooltip
            }
            sldr.Value = math.clamp(sldr.Value, sldr.Min, sldr.Max)

            local f = Instance.new("Frame")
            f.Size = UDim2.new(1, 0, 0, 52)
            f.Parent = Container
            Utility:CreateCorner(8, f)
            ThemeManager:Register(f, {BackgroundColor3 = "Card"})
            local stroke = Utility:CreateStroke(1, Color3.new(1,1,1), 0, f)
            ThemeManager:Register(stroke, {Color = "Border"})

            local lbl = Instance.new("TextLabel")
            lbl.BackgroundTransparency = 1
            lbl.Position = UDim2.new(0, 12, 0, 6)
            lbl.Size = UDim2.new(1, -64, 0, 16)
            lbl.FontFace = Font.new("rbxasset://fonts/families/GothamSSm.json", Enum.FontWeight.Medium)
            lbl.Text = sldr.Name
            lbl.TextSize = 13
            lbl.TextXAlignment = Enum.TextXAlignment.Left
            lbl.Parent = f
            ThemeManager:Register(lbl, {TextColor3 = "Text2"})

            local valBox = Instance.new("TextBox")
            valBox.BackgroundTransparency = 1
            valBox.Position = UDim2.new(1, -50, 0, 6)
            valBox.Size = UDim2.new(0, 38, 0, 16)
            valBox.FontFace = Font.new("rbxasset://fonts/families/GothamSSm.json", Enum.FontWeight.Bold)
            valBox.Text = tostring(sldr.Value)
            valBox.TextSize = 12
            valBox.TextXAlignment = Enum.TextXAlignment.Right
            valBox.CursorPosition = -1
            valBox.Parent = f
            ThemeManager:Register(valBox, {TextColor3 = "Accent", PlaceholderColor3 = "TextDim"})

            local track = Instance.new("TextButton")
            track.AutoButtonColor = false
            track.Text = ""
            track.Position = UDim2.new(0, 12, 0, 32)
            track.Size = UDim2.new(1, -24, 0, 6)
            track.Parent = f
            Utility:CreateCorner(3, track)
            ThemeManager:Register(track, {BackgroundColor3 = "ValueBg"})
            
            local fill = Instance.new("Frame")
            fill.Size = UDim2.new((sldr.Value - sldr.Min) / (sldr.Max - sldr.Min), 0, 1, 0)
            fill.Parent = track
            Utility:CreateCorner(3, fill)
            ThemeManager:Register(fill, {BackgroundColor3 = "Accent"})
            
            local circ = Instance.new("Frame")
            circ.AnchorPoint = Vector2.new(0.5, 0.5)
            circ.Position = UDim2.new(1, 0, 0.5, 0)
            circ.Size = UDim2.new(0, 12, 0, 12)
            circ.Parent = fill
            Utility:CreateCorner(6, circ)
            ThemeManager:Register(circ, {BackgroundColor3 = "Text1"})
            
            local api = self:AddElement(sldr.Flag, "Slider", f)
            local dragging = false

            local function updateValue(val)
                val = Utility:Round(math.clamp(val, sldr.Min, sldr.Max), string.find(tostring(sldr.Inc), "%.") and #tostring(sldr.Inc):split(".")[2] or 0)
                
                -- Snap to increment
                val = val - val % sldr.Inc
                val = math.clamp(val, sldr.Min, sldr.Max)
                
                if sldr.Value ~= val then
                    sldr.Value = val
                    valBox.Text = tostring(val)
                    Utility:Tween(fill, HihlLib.TweenData.Fast, {Size = UDim2.new((val - sldr.Min) / (sldr.Max - sldr.Min), 0, 1, 0)})
                    task.spawn(sldr.Callback, val)
                end
            end
            
            local function updatePos(input)
                local perc = math.clamp((input.Position.X - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
                updateValue(sldr.Min + (sldr.Max - sldr.Min) * perc)
            end

            track.InputBegan:Connect(function(i)
                if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
                    dragging = true
                    updatePos(i)
                    Utility:Tween(circ, HihlLib.TweenData.Micro, {Size = UDim2.new(0,16,0,16)})
                end
            end)

            UserInputService.InputChanged:Connect(function(i)
                if dragging and (i.UserInputType == Enum.UserInputType.MouseMovement or i.UserInputType == Enum.UserInputType.Touch) then
                    updatePos(i)
                end
            end)

            UserInputService.InputEnded:Connect(function(i)
                if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
                    if dragging then
                        dragging = false
                        Utility:Tween(circ, HihlLib.TweenData.Smooth, {Size = UDim2.new(0,12,0,12)})
                    end
                end
            end)

            valBox.FocusLost:Connect(function()
                local n = tonumber(valBox.Text)
                if n then updateValue(n) else valBox.Text = tostring(sldr.Value) end
            end)

            f.InputBegan:Connect(function(i)
                if i.UserInputType == Enum.UserInputType.MouseMovement then
                    Utility:Tween(f, HihlLib.TweenData.Fast, {BackgroundColor3 = ThemeManager:GetColor("CardHover")})
                    Utility:Tween(stroke, HihlLib.TweenData.Fast, {Color = ThemeManager:GetColor("BorderHover")})
                    Utility:Tween(lbl, HihlLib.TweenData.Fast, {TextColor3 = ThemeManager:GetColor("Text1")})
                end
            end)
            f.InputEnded:Connect(function(i)
                if i.UserInputType == Enum.UserInputType.MouseMovement then
                    Utility:Tween(f, HihlLib.TweenData.Smooth, {BackgroundColor3 = ThemeManager:GetColor("Card")})
                    Utility:Tween(stroke, HihlLib.TweenData.Smooth, {Color = ThemeManager:GetColor("Border")})
                    Utility:Tween(lbl, HihlLib.TweenData.Smooth, {TextColor3 = ThemeManager:GetColor("Text2")})
                end
            end)

            if sldr.Tooltip then Window:SetTooltip(f, sldr.Tooltip) end
            function api:Set(v) updateValue(v) end
            function api:Get() return sldr.Value end
            return api
        end

