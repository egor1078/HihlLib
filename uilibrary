                            task.spawn(function() f.MouseButton1Click:Fire() end)
                        end
                    end
                end)
                
                if not Window.Keybinds then Window.Keybinds = {} end
                table.insert(Window.Keybinds, tgl)
                task.spawn(function() Window:UpdateKeybinds() end)
            end

            local api = self:AddElement(tgl.Flag, "Toggle", f)

            local function setState(state)
                if state == nil then state = not tgl.Value end
                tgl.Value = state
                Utility:Tween(bg, HihlLib.TweenData.Fast, {BackgroundColor3 = tgl.Value and ThemeManager:GetColor("Accent") or ThemeManager:GetColor("ToggleTrack")})
                Utility:Tween(circ, HihlLib.TweenData.Pop, {
                    Position = UDim2.new(0, tgl.Value and 20 or 2, 0.5, 0),
                    BackgroundColor3 = tgl.Value and Color3.new(1,1,1) or ThemeManager:GetColor("ToggleOff")
                })
                Utility:Tween(lbl, HihlLib.TweenData.Fast, {TextColor3 = tgl.Value and ThemeManager:GetColor("Text1") or ThemeManager:GetColor("Text2")})
                task.spawn(tgl.Callback, tgl.Value)
            end

            f.MouseButton1Click:Connect(function() setState() end)
            f.InputBegan:Connect(function(i)
                if i.UserInputType == Enum.UserInputType.MouseMovement then
                    Utility:Tween(f, HihlLib.TweenData.Fast, {BackgroundColor3 = ThemeManager:GetColor("CardHover")})
                    Utility:Tween(stroke, HihlLib.TweenData.Fast, {Color = ThemeManager:GetColor("BorderHover")})
                end
            end)
            f.InputEnded:Connect(function(i)
