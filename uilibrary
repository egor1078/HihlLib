					tween(label, Tw.Silk, {TextColor3 = Theme.Text2})
				end
				task.spawn(callback, on)
			end

			track.MouseButton1Click:Connect(function()
				setToggle(not on)
			end)

			local toggleAPI = {}
			function toggleAPI:Set(val) if val ~= on then setToggle(val) end end
			function toggleAPI:Get() return on end
			return toggleAPI
		end

		function Tab:CreateSlider(cfg)
			cfg = cfg or {}
			tabData.itemCount = tabData.itemCount + 1
			local min = cfg.Min or 0
			local max = cfg.Max or 100
			local default = math.clamp(cfg.Default or min, min, max)
			local increment = cfg.Increment or 1
			local callback = cfg.Callback or function() end
			local currentValue = default

			local frame = Instance.new("Frame")
			frame.Name = "Slider_" .. (cfg.Name or "Slider")
			frame.BackgroundColor3 = Theme.Card
			frame.LayoutOrder = tabData.itemCount
			frame.Size = UDim2.new(1, 0, 0, 50)
			frame.ZIndex = 11
			frame.Parent = container
			corner(frame, UDim.new(0, 10))
