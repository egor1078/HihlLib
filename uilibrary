	Window.currentTab = nil
	Window.locked = false
	Window.visible = true

	local fullSize = UDim2.new(0, 245, 0, 220)
	local miniSize = UDim2.new(0, 195, 0, 155)
	local gap = 10

	local function isAbove()
		return navbar.AbsolutePosition.Y < gui.AbsoluteSize.Y * 0.4
	end

	local function getCenter()
		local p = navbar.Position
		local nh = navbar.AbsoluteSize.Y
		local ph = fullSize.Y.Offset
		local below = isAbove()
		local oy = below and (nh/2 + gap + ph/2) or -(nh/2 + gap + ph/2)
		return UDim2.new(p.X.Scale, p.X.Offset, p.Y.Scale, p.Y.Offset + oy)
	end

	local function getShifted(side)
		local c = getCenter()
		local ox = side == "left" and -50 or 50
		return UDim2.new(c.X.Scale, c.X.Offset + ox, c.Y.Scale, c.Y.Offset)
	end

	local function activateBtn(tab)
		tab.active = true
		tw(tab.icon, Tw.Fast, {ImageColor3 = Theme.Accent})
		tw(tab.holder, Tw.Fast, {BackgroundTransparency = 0.8})
		tw(tab.indicator, Tw.Fast, {Size = UDim2.new(0, 14, 0, 2)})
	end

	local function deactivateBtn(tab)
		tab.active = false
		tw(tab.icon, Tw.Silk, {ImageColor3 = Theme.IconIdle})
		tw(tab.holder, Tw.Silk, {BackgroundTransparency = 1})
		tw(tab.indicator, Tw.Silk, {Size = UDim2.new(0, 0, 0, 2)})
	end

	local function openTab(name)
		if Window.locked then return end
		Window.locked = true
		local tab = Window.tabs[name]
		if not tab then Window.locked = false return end
		local page = tab.page
		local ps = tab.pageStroke
		local al = tab.accentLine

		if Window.currentTab == name then
			Window.currentTab = nil
			deactivateBtn(tab)
			if al then tw(al, Tw.Fast, {Size = UDim2.new(0, 0, 0, 2)}) end
			if ps then tw(ps, Tw.Fast, {Transparency = 1}) end
			local t = tw(page, Tw.Silk, {Size = miniSize, GroupTransparency = 1})
			t.Completed:Connect(function()
				if Window.currentTab ~= name then page.Visible = false end
				Window.locked = false
			end)
			return
		end

		if Window.currentTab then
			local old = Window.tabs[Window.currentTab]
			if old then
				deactivateBtn(old)
				if old.accentLine then tw(old.accentLine, Tw.Fast, {Size = UDim2.new(0, 0, 0, 2)}) end
				if old.pageStroke then tw(old.pageStroke, Tw.Fast, {Transparency = 1}) end
				local exitSide = tab.order > old.order and "left" or "right"
				local enterSide = tab.order > old.order and "right" or "left"
				local et = tw(old.page, Tw.Silk, {Position = getShifted(exitSide), Size = miniSize, GroupTransparency = 1})
				et.Completed:Connect(function() old.page.Visible = false end)

				page.Position = getShifted(enterSide)
				page.Size = miniSize
				page.GroupTransparency = 1
				page.Visible = true
				if ps then ps.Transparency = 1 end
				if al then al.Size = UDim2.new(0, 0, 0, 2) end
				Window.currentTab = name
				activateBtn(tab)

				task.spawn(function()
					task.wait(0.02)
					tw(page, Tw.Slow, {Position = getCenter(), Size = fullSize, GroupTransparency = 0})
					if ps then tw(ps, Tw.Slow, {Transparency = 0}) end
					task.wait(0.18)
					if al and Window.currentTab == name then tw(al, Tw.Silk, {Size = UDim2.new(0.25, 0, 0, 2)}) end
					task.wait(0.25)
					Window.locked = false
				end)
			end
		else
			page.Position = getCenter()
			page.Size = miniSize
			page.GroupTransparency = 1
			page.Visible = true
			if ps then ps.Transparency = 1 end
			if al then al.Size = UDim2.new(0, 0, 0, 2) end
			Window.currentTab = name
			activateBtn(tab)

			task.spawn(function()
				tw(page, Tw.Slow, {Size = fullSize, GroupTransparency = 0})
				if ps then tw(ps, Tw.Slow, {Transparency = 0}) end
				task.wait(0.18)
				if al and Window.currentTab == name then tw(al, Tw.Silk, {Size = UDim2.new(0.25, 0, 0, 2)}) end
				task.wait(0.3)
				Window.locked = false
			end)
		end
	end

	makeDraggable(navbar, navbar, function()
		if Window.currentTab then
			local tab = Window.tabs[Window.currentTab]
			if tab and tab.page.GroupTransparency < 0.3 then
				tab.page.Position = getCenter()
			end
		end
	end)

	UserInputService.InputBegan:Connect(function(input, gpe)
		if gpe then return end
		if input.KeyCode == toggleKey then
			Window.visible = not Window.visible
			gui.Enabled = Window.visible
		end
