                Utility:Tween(old.Page, HihlLib.TweenData.Smooth, {Size = exitScale, GroupTransparency = 1}).Completed:Connect(function()
                    if old.Active == false then old.Page.Visible = false end
                end)
            end

            self.ActiveTab = TName
            Tab.Active = true
            Utility:Tween(Icon, HihlLib.TweenData.Fast, {ImageColor3 = ThemeManager:GetColor("Accent")})
            Utility:Tween(Indicator, HihlLib.TweenData.Smooth, {Size = UDim2.new(0,14,0,2)})
            
