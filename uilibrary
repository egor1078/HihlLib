            Page.Visible = true
            PageStroke.Transparency = 1
            AccentLine.Size = UDim2.new(0,0,0,2)

            Utility:Tween(Page, HihlLib.TweenData.Slow, {Size = Sizes.Full, GroupTransparency = 0})
