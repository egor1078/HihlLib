        function Tab:AddElement(id, eType, mainFrame, apiObj)
            apiObj = apiObj or {}
            self.ItemCount = self.ItemCount + 1
            mainFrame.LayoutOrder = self.ItemCount
            
            function apiObj:Hide() mainFrame.Visible = false end
            function apiObj:Show() mainFrame.Visible = true end
            function apiObj:Destroy()
                if SaveManager.Options[id] then SaveManager.Options[id] = nil end
                ThemeManager.Objects[mainFrame] = nil
                for _, child in pairs(mainFrame:GetDescendants()) do
                    ThemeManager.Objects[child] = nil
                end
                mainFrame:Destroy()
            end

            if id then
                apiObj.Type = eType
                SaveManager:Add(id, apiObj)
            end
            return apiObj
        end

