				if not bar or not bar.Parent then return end
				local bx, bw = bar.AbsolutePosition.X, bar.AbsoluteSize.X
				if bw <= 0 then return end
				local p = math.clamp((inputX - bx) / bw, 0, 1)
				local raw = min + (max - min) * p
				local snapped = math.clamp(math.floor(raw / inc + 0.5) * inc, min, max)
				local sp = (snapped - min) / math.max(max - min, 1)
				fill.Size = UDim2.new(sp, 0, 1, 0)
				knob.Position = UDim2.new(sp, 0, 0.5, 0)
				vl.Text = tostring(snapped)
				if snapped ~= cur then cur = snapped; task.spawn(cb, snapped) end
			end

			trigger.MouseButton1Down:Connect(function() sliding = true; tw(knob, Tw.Spring, {Size = UDim2.new(0,16,0,16)}) end)
			UserInputService.InputEnded:Connect(function(i) if (i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch) and sliding then sliding = false; tw(knob, Tw.Spring, {Size = UDim2.new(0,12,0,12)}) end end)
			renderEvent:Connect(function() if not sliding then return end; local ok, mp = pcall(function() return UserInputService:GetMouseLocation() end); if ok then updateSlider(mp.X) end end)

			local api = {}
			function api:Set(v) v = math.clamp(v, min, max); local sn = math.clamp(math.floor(v/inc+0.5)*inc, min, max); cur = sn; local p = (sn-min)/math.max(max-min,1); tw(fill, Tw.Silk, {Size = UDim2.new(p,0,1,0)}); tw(knob, Tw.Silk, {Position = UDim2.new(p,0,0.5,0)}); vl.Text = tostring(sn); task.spawn(cb, sn) end
			function api:Get() return cur end
			return api
		end

