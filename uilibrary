                            tgl.Keybind.Value = i.KeyCode
                            kbBtn.Text = i.KeyCode.Name
                            Utility:Tween(kbBtn, HihlLib.TweenData.Smooth, {TextColor3 = ThemeManager:GetColor("Text2")})
                            if tgl.Keybind.Callback then task.spawn(tgl.Keybind.Callback, i.KeyCode) end
                            if Window.Keybinds then Window:UpdateKeybinds() end
                        end
                    elseif not gpe and tgl.Keybind.Value and i.KeyCode == tgl.Keybind.Value then
                        Utility:Tween(kbBtn, HihlLib.TweenData.Micro, {BackgroundColor3 = ThemeManager:GetColor("Accent"), TextColor3 = Color3.new(1,1,1)})
