local function tween(obj, info, props)
	local t = TweenService:Create(obj, info, props)
	t:Play()
	return t
end

local function corner(parent, radius)
	local c = Instance.new("UICorner")
	c.CornerRadius = radius or UDim.new(0, 10)
	c.Parent = parent
	return c
end

local function stroke(parent, color, thickness, transparency)
	local s = Instance.new("UIStroke")
	s.Color = color or Theme.Border
	s.Thickness = thickness or 1
	s.Transparency = transparency or 0
	s.Parent = parent
	return s
end

local function accentGradient()
	local g = Instance.new("UIGradient")
	g.Color = ColorSequence.new({
		ColorSequenceKeypoint.new(0, Theme.AccentDark),
		ColorSequenceKeypoint.new(0.5, Theme.AccentBright),
		ColorSequenceKeypoint.new(1, Theme.AccentDark),
	})
	return g
end

local function fillGradient()
	local g = Instance.new("UIGradient")
	g.Color = ColorSequence.new({
		ColorSequenceKeypoint.new(0, Theme.AccentDark),
		ColorSequenceKeypoint.new(1, Theme.AccentLight),
	})
	return g
end

local function hoverEffect(frame, frameStroke)
	frame.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseMovement then
			tween(frame, Tw.Hover, {BackgroundColor3 = Theme.CardHover})
			if frameStroke then tween(frameStroke, Tw.Hover, {Color = Theme.BorderHover}) end
		end
	end)
	frame.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseMovement then
			tween(frame, Tw.Hover, {BackgroundColor3 = Theme.Card})
			if frameStroke then tween(frameStroke, Tw.Hover, {Color = Theme.Border}) end
		end
	end)
end

-- Drag system — uses RenderStepped for frame-perfect movement
local function makeDraggable(handle, target, onDrag)
	local dragging = false
	local dragStart = Vector3.new(0, 0, 0)
	local startPos = UDim2.new()

	handle.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1
			or input.UserInputType == Enum.UserInputType.Touch then
			dragging = true
			dragStart = input.Position
			startPos = target.Position
			input.Changed:Connect(function()
				if input.UserInputState == Enum.UserInputState.End then
					dragging = false
				end
			end)
		end
	end)

	local renderConn = (RunService.RenderStepped or RunService.Heartbeat)
	renderConn:Connect(function()
		if not dragging then return end
		local ok, mousePos = pcall(function() return UserInputService:GetMouseLocation() end)
		if not ok then return end
		local delta = Vector2.new(mousePos.X, mousePos.Y) - Vector2.new(dragStart.X, dragStart.Y)
		local newPos = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
		target.Position = newPos
		if onDrag then onDrag() end
	end)
end

local HihlLib = {}

function HihlLib:CreateWindow(config)
	config = config or {}
	local title = config.Title or "Hihl Hub"
	local toggleKey = config.ToggleKey or Enum.KeyCode.RightShift

	local gui = Instance.new("ScreenGui")
	gui.Name = title:gsub("%s", "") .. "_UI"
	gui.ResetOnSpawn = false
	gui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
	gui.Parent = getGuiParent()

	local navbar = Instance.new("Frame")
	navbar.Name = "Navbar"
	navbar.AnchorPoint = Vector2.new(0.5, 0.5)
	navbar.BackgroundColor3 = Theme.Bg
	navbar.BorderSizePixel = 0
	navbar.Position = UDim2.new(0.5, 0, 0.85, 0)
	navbar.Size = UDim2.new(0, 0, 0, 46)
	navbar.ZIndex = 20
	navbar.Parent = gui
	corner(navbar, UDim.new(0, 14))
	stroke(navbar, Theme.BorderLight)

	local navLayout = Instance.new("UIListLayout")
	navLayout.FillDirection = Enum.FillDirection.Horizontal
	navLayout.HorizontalAlignment = Enum.HorizontalAlignment.Center
	navLayout.VerticalAlignment = Enum.VerticalAlignment.Center
	navLayout.Padding = UDim.new(0, 4)
	navLayout.SortOrder = Enum.SortOrder.LayoutOrder
	navLayout.Parent = navbar

	local pages = Instance.new("Folder")
	pages.Name = "Pages"
	pages.Parent = gui

	-- State
	local Window = {}
	Window.gui = gui
	Window.navbar = navbar
	Window.pages = pages
	Window.tabs = {}
	Window.tabOrder = {}
	Window.currentTab = nil
	Window.locked = false
	Window.visible = true

	local fullSize = UDim2.new(0, 245, 0, 220)
	local miniSize = UDim2.new(0, 195, 0, 155)
	local gap = 10

	local function isAbove()
		return navbar.AbsolutePosition.Y < gui.AbsoluteSize.Y * 0.4
	end

	local function getCenter()
		local p = navbar.Position
		local nh = navbar.AbsoluteSize.Y
		local ph = fullSize.Y.Offset
		local below = isAbove()
		local oy = below and (nh / 2 + gap + ph / 2) or -(nh / 2 + gap + ph / 2)
		return UDim2.new(p.X.Scale, p.X.Offset, p.Y.Scale, p.Y.Offset + oy)
	end

	local function getShifted(side)
		local c = getCenter()
		local s = 50
		local ox = side == "left" and -s or s
		return UDim2.new(c.X.Scale, c.X.Offset + ox, c.Y.Scale, c.Y.Offset)
	end

	local function activateBtn(tab)
		tab.active = true
		tween(tab.icon, Tw.Fast, {ImageColor3 = Theme.Accent})
		tween(tab.holder, Tw.Fast, {BackgroundTransparency = 0.8})
		tween(tab.indicator, Tw.Fast, {Size = UDim2.new(0, 14, 0, 2)})
	end

	local function deactivateBtn(tab)
		tab.active = false
		tween(tab.icon, Tw.Silk, {ImageColor3 = Theme.IconIdle})
		tween(tab.holder, Tw.Silk, {BackgroundTransparency = 1})
		tween(tab.indicator, Tw.Silk, {Size = UDim2.new(0, 0, 0, 2)})
	end

	local function openTab(name)
		if Window.locked then return end
		Window.locked = true

		local tab = Window.tabs[name]
		if not tab then Window.locked = false return end
		local page = tab.page
		local pageStroke = tab.pageStroke
		local accentLine = tab.accentLine

		if Window.currentTab == name then
			-- Close current
			Window.currentTab = nil
			deactivateBtn(tab)
			if accentLine then tween(accentLine, Tw.Fast, {Size = UDim2.new(0, 0, 0, 2)}) end
			if pageStroke then tween(pageStroke, Tw.Fast, {Transparency = 1}) end
			local t = tween(page, Tw.Silk, {Size = miniSize, GroupTransparency = 1})
			t.Completed:Connect(function()
				if Window.currentTab ~= name then page.Visible = false end
				Window.locked = false
			end)
			return
		end

		if Window.currentTab then
			local oldTab = Window.tabs[Window.currentTab]
			if oldTab then
				local oldPage = oldTab.page
				deactivateBtn(oldTab)
				if oldTab.accentLine then tween(oldTab.accentLine, Tw.Fast, {Size = UDim2.new(0, 0, 0, 2)}) end
				if oldTab.pageStroke then tween(oldTab.pageStroke, Tw.Fast, {Transparency = 1}) end

				local exitSide = tab.order > oldTab.order and "left" or "right"
				local enterSide = tab.order > oldTab.order and "right" or "left"

				local exitT = tween(oldPage, Tw.Silk, {Position = getShifted(exitSide), Size = miniSize, GroupTransparency = 1})
				exitT.Completed:Connect(function() oldPage.Visible = false end)


				page.Position = getShifted(enterSide)
				page.Size = miniSize
				page.GroupTransparency = 1
				page.Visible = true
				if pageStroke then pageStroke.Transparency = 1 end
				if accentLine then accentLine.Size = UDim2.new(0, 0, 0, 2) end

				Window.currentTab = name
				activateBtn(tab)

				task.defer(function()
					tween(page, Tw.Slow, {Position = getCenter(), Size = fullSize, GroupTransparency = 0})
					if pageStroke then tween(pageStroke, Tw.Slow, {Transparency = 0}) end
					task.wait(0.18)
					if accentLine and Window.currentTab == name then
						tween(accentLine, Tw.Silk, {Size = UDim2.new(0.25, 0, 0, 2)})
					end
					task.wait(0.25)
					Window.locked = false
				end)
			end
		else
			-- First open
			page.Position = getCenter()
			page.Size = miniSize
			page.GroupTransparency = 1
			page.Visible = true
			if pageStroke then pageStroke.Transparency = 1 end
			if accentLine then accentLine.Size = UDim2.new(0, 0, 0, 2) end

			Window.currentTab = name
			activateBtn(tab)

			task.defer(function()
				tween(page, Tw.Slow, {Size = fullSize, GroupTransparency = 0})
				if pageStroke then tween(pageStroke, Tw.Slow, {Transparency = 0}) end
				task.wait(0.18)
				if accentLine and Window.currentTab == name then
					tween(accentLine, Tw.Silk, {Size = UDim2.new(0.25, 0, 0, 2)})
				end
				task.wait(0.3)
				Window.locked = false
			end)
		end
	end

	-- Drag follow — page follows navbar in real time
	makeDraggable(navbar, navbar, function()
		if Window.currentTab then
			local tab = Window.tabs[Window.currentTab]
			if tab and tab.page.GroupTransparency < 0.3 then
				tab.page.Position = getCenter()
			end
		end
	end)

	-- Toggle visibility with key
	UserInputService.InputBegan:Connect(function(input, gpe)
		if gpe then return end
		if input.KeyCode == toggleKey then
			Window.visible = not Window.visible
			gui.Enabled = Window.visible
		end
	end)

