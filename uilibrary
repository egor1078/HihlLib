local Tw = {
	Smooth = TweenInfo.new(0.3, Enum.EasingStyle.Quint, Enum.EasingDirection.Out),
	Slow   = TweenInfo.new(0.45, Enum.EasingStyle.Quint, Enum.EasingDirection.Out),
	Fast   = TweenInfo.new(0.18, Enum.EasingStyle.Quint, Enum.EasingDirection.Out),
	Snap   = TweenInfo.new(0.06, Enum.EasingStyle.Quad,  Enum.EasingDirection.Out),
	Pop    = TweenInfo.new(0.4,  Enum.EasingStyle.Back,  Enum.EasingDirection.Out),
	Micro  = TweenInfo.new(0.1,  Enum.EasingStyle.Quad,  Enum.EasingDirection.Out),
}

local renderEvent = RunService.RenderStepped or RunService.Heartbeat

local function tw(obj, info, props)
	local t = TweenService:Create(obj, info, props)
	t:Play()
	return t
end

local function corner(p, r) local c = Instance.new("UICorner"); c.CornerRadius = r or UDim.new(0, 10); c.Parent = p; return c end
local function addStroke(p, col, th, tr) local s = Instance.new("UIStroke"); s.Color = col or Theme.Border; s.Thickness = th or 1; s.Transparency = tr or 0; s.Parent = p; return s end

local function accentGrad()
	local g = Instance.new("UIGradient")
	g.Color = ColorSequence.new({ColorSequenceKeypoint.new(0, Theme.AccentDark), ColorSequenceKeypoint.new(0.5, Theme.AccentBright), ColorSequenceKeypoint.new(1, Theme.AccentDark)})
	return g
end

local function fillGrad()
	local g = Instance.new("UIGradient")
	g.Color = ColorSequence.new({ColorSequenceKeypoint.new(0, Theme.AccentDark), ColorSequenceKeypoint.new(1, Theme.AccentLight)})
	return g
end

local function hoverFx(frame, fs)
	frame.InputBegan:Connect(function(i)
		if i.UserInputType == Enum.UserInputType.MouseMovement then
			tw(frame, Tw.Fast, {BackgroundColor3 = Theme.CardHover})
			if fs then tw(fs, Tw.Fast, {Color = Theme.BorderHover}) end
		elseif i.UserInputType == Enum.UserInputType.Touch then
			tw(frame, Tw.Micro, {BackgroundColor3 = Theme.CardHover})
		end
	end)
	frame.InputEnded:Connect(function(i)
		if i.UserInputType == Enum.UserInputType.MouseMovement or i.UserInputType == Enum.UserInputType.Touch then
			tw(frame, Tw.Fast, {BackgroundColor3 = Theme.Card})
			if fs then tw(fs, Tw.Fast, {Color = Theme.Border}) end
		end
	end)
end

local function makeDraggable(handle, target, onDrag)
	local dragging = false
	local dragStart, startPos, lastPos

	handle.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = true
			dragStart = input.Position
			startPos = target.Position
			lastPos = input.Position
			input.Changed:Connect(function()
				if input.UserInputState == Enum.UserInputState.End then dragging = false end
			end)
		end
	end)

	handle.InputChanged:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
			lastPos = input.Position
		end
	end)

	UserInputService.InputChanged:Connect(function(input)
		if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
			lastPos = input.Position
		end
	end)

	renderEvent:Connect(function()
		if not dragging or not lastPos then return end
		local dx = lastPos.X - dragStart.X
		local dy = lastPos.Y - dragStart.Y
		target.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + dx, startPos.Y.Scale, startPos.Y.Offset + dy)
		if onDrag then onDrag() end
	end)
end

local HihlLib = {}

function HihlLib:CreateWindow(config)
	config = config or {}
	local title = config.Title or "Hihl Hub"
	local toggleKey = config.ToggleKey or Enum.KeyCode.RightShift

	local gui = Instance.new("ScreenGui")
	gui.Name = title:gsub("%s", "") .. "_UI"
	gui.ResetOnSpawn = false
	gui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
	gui.Parent = playerGui

	local navbar = Instance.new("Frame")
	navbar.Name = "Navbar"
	navbar.AnchorPoint = Vector2.new(0.5, 0.5)
	navbar.BackgroundColor3 = Theme.Bg
	navbar.BorderSizePixel = 0
	navbar.Position = UDim2.new(0.5, 0, 0.85, 0)
	navbar.Size = UDim2.new(0, 0, 0, 46)
	navbar.ZIndex = 20
	navbar.Parent = gui
	corner(navbar, UDim.new(0, 14))
	addStroke(navbar, Theme.BorderLight)

	local nl = Instance.new("UIListLayout")
	nl.FillDirection = Enum.FillDirection.Horizontal
	nl.HorizontalAlignment = Enum.HorizontalAlignment.Center
	nl.VerticalAlignment = Enum.VerticalAlignment.Center
	nl.Padding = UDim.new(0, 4)
	nl.SortOrder = Enum.SortOrder.LayoutOrder
	nl.Parent = navbar

	local pages = Instance.new("Folder")
	pages.Name = "Pages"
	pages.Parent = gui

	local Window = {}
	Window.gui = gui
	Window.navbar = navbar
	Window.tabs = {}
	Window.tabOrder = {}
	Window.currentTab = nil
	Window.locked = false
	Window.visible = true

	local fullSize = UDim2.new(0, 245, 0, 220)
	local miniSize = UDim2.new(0, 200, 0, 165)
	local gap = 10

	local function getPagePos()
		local np = navbar.Position
		local ny = navbar.AbsolutePosition.Y
		local sy = gui.AbsoluteSize.Y
		local nh = navbar.AbsoluteSize.Y
		local ph = fullSize.Y.Offset

		local spaceAbove = ny
		local spaceBelow = sy - ny - nh

		local offset
		if spaceBelow >= ph + gap then
			offset = nh / 2 + gap + ph / 2
		elseif spaceAbove >= ph + gap then
			offset = -(nh / 2 + gap + ph / 2)
		elseif spaceBelow >= spaceAbove then
			offset = nh / 2 + gap + ph / 2
		else
			offset = -(nh / 2 + gap + ph / 2)
		end

		return UDim2.new(np.X.Scale, np.X.Offset, np.Y.Scale, np.Y.Offset + offset)
	end

	local function getShifted(side)
		local c = getPagePos()
		local ox = side == "left" and -45 or 45
		return UDim2.new(c.X.Scale, c.X.Offset + ox, c.Y.Scale, c.Y.Offset)
	end

	local function activateBtn(tab)
		tab.active = true
		tw(tab.icon, Tw.Fast, {ImageColor3 = Theme.Accent})
		tw(tab.holder, Tw.Fast, {BackgroundTransparency = 0.8})
		tw(tab.indicator, Tw.Smooth, {Size = UDim2.new(0, 14, 0, 2)})
	end

	local function deactivateBtn(tab)
		tab.active = false
		tw(tab.icon, Tw.Smooth, {ImageColor3 = Theme.IconIdle})
		tw(tab.holder, Tw.Smooth, {BackgroundTransparency = 1})
		tw(tab.indicator, Tw.Smooth, {Size = UDim2.new(0, 0, 0, 2)})
	end

	local function openTab(name)
		if Window.locked then return end
		Window.locked = true
		local tab = Window.tabs[name]
		if not tab then Window.locked = false return end
		local pg = tab.page
		local ps = tab.pageStroke
		local al = tab.accentLine

		if Window.currentTab == name then
			Window.currentTab = nil
			deactivateBtn(tab)
			if al then tw(al, Tw.Fast, {Size = UDim2.new(0, 0, 0, 2)}) end
			if ps then tw(ps, Tw.Fast, {Transparency = 1}) end
			local t = tw(pg, Tw.Smooth, {Size = miniSize, GroupTransparency = 1})
			t.Completed:Connect(function()
				if Window.currentTab ~= name then pg.Visible = false end
				Window.locked = false
			end)
			return
		end

		if Window.currentTab then
			local old = Window.tabs[Window.currentTab]
			if old then
				deactivateBtn(old)
				if old.accentLine then tw(old.accentLine, Tw.Fast, {Size = UDim2.new(0, 0, 0, 2)}) end
				if old.pageStroke then tw(old.pageStroke, Tw.Fast, {Transparency = 1}) end
				local exitSide = tab.order > old.order and "left" or "right"
				local enterSide = tab.order > old.order and "right" or "left"
				local et = tw(old.page, Tw.Smooth, {Position = getShifted(exitSide), Size = miniSize, GroupTransparency = 1})
				et.Completed:Connect(function() old.page.Visible = false end)

				pg.Position = getShifted(enterSide)
				pg.Size = miniSize
				pg.GroupTransparency = 1
				pg.Visible = true
				if ps then ps.Transparency = 1 end
				if al then al.Size = UDim2.new(0, 0, 0, 2) end
				Window.currentTab = name
				activateBtn(tab)

				task.spawn(function()
					task.wait(0.02)
					tw(pg, Tw.Slow, {Position = getPagePos(), Size = fullSize, GroupTransparency = 0})
					if ps then tw(ps, Tw.Slow, {Transparency = 0}) end
					task.wait(0.15)
					if al and Window.currentTab == name then tw(al, Tw.Smooth, {Size = UDim2.new(0.25, 0, 0, 2)}) end
					task.wait(0.2)
					Window.locked = false
				end)
			end
		else
			pg.Position = getPagePos()
			pg.Size = miniSize
			pg.GroupTransparency = 1
			pg.Visible = true
			if ps then ps.Transparency = 1 end
			if al then al.Size = UDim2.new(0, 0, 0, 2) end
			Window.currentTab = name
			activateBtn(tab)

			task.spawn(function()
				tw(pg, Tw.Slow, {Size = fullSize, GroupTransparency = 0})
				if ps then tw(ps, Tw.Slow, {Transparency = 0}) end
				task.wait(0.15)
				if al and Window.currentTab == name then tw(al, Tw.Smooth, {Size = UDim2.new(0.25, 0, 0, 2)}) end
				task.wait(0.25)
				Window.locked = false
			end)
		end
	end

	makeDraggable(navbar, navbar, function()
		if Window.currentTab then
			local tab = Window.tabs[Window.currentTab]
			if tab and tab.page.GroupTransparency < 0.3 then
				tab.page.Position = getPagePos()
			end
		end
	end)

	UserInputService.InputBegan:Connect(function(input, gpe)
		if gpe then return end
		if input.KeyCode == toggleKey then
			Window.visible = not Window.visible
			gui.Enabled = Window.visible
		end
	end)

