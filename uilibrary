				optBtn.TextColor3 = opt == current and Theme.Accent or Theme.Text2
				optBtn.TextSize = 11
				optBtn.LayoutOrder = i
				optBtn.Parent = optionList
				corner(optBtn, UDim.new(0, 6))

				optBtn.MouseButton1Click:Connect(function()
					current = opt
					selected.Text = opt
					for _, c in ipairs(optionList:GetChildren()) do
						if c:IsA("TextButton") then
							tween(c, Tw.Fast, {TextColor3 = c.Text == opt and Theme.Accent or Theme.Text2})
						end
					end
					-- Auto-close dropdown
					isOpen = false
					tween(frame, Tw.Silk, {Size = UDim2.new(1, 0, 0, 38)})
					task.spawn(callback, opt)
				end)

				optBtn.InputBegan:Connect(function(input)
					if input.UserInputType == Enum.UserInputType.MouseMovement then
						tween(optBtn, Tw.Micro, {BackgroundTransparency = 0})
					end
				end)
				optBtn.InputEnded:Connect(function(input)
					if input.UserInputType == Enum.UserInputType.MouseMovement then
						tween(optBtn, Tw.Micro, {BackgroundTransparency = 0.5})
					end
				end)
			end

			selected.MouseButton1Click:Connect(function()
				isOpen = not isOpen
				local targetH = isOpen and (38 + #options * 28 + 10) or 38
				tween(frame, Tw.Spring, {Size = UDim2.new(1, 0, 0, targetH)})
			end)

			hoverEffect(frame, fStroke)

			local dropAPI = {}
			function dropAPI:Set(val) selected.Text = val; current = val; task.spawn(callback, val) end
			function dropAPI:Get() return current end
			return dropAPI
		end

