                end)

                UserInputService.InputBegan:Connect(function(i, gpe)
                    if binding then
                        if i.KeyCode == Enum.KeyCode.Backspace or i.KeyCode == Enum.KeyCode.Escape then
                            binding = false
                            kbBtn.Text = tgl.Keybind.Value and tgl.Keybind.Value.Name or "None"
                            Utility:Tween(kbBtn, HihlLib.TweenData.Smooth, {TextColor3 = ThemeManager:GetColor("Text2")})
                        elseif i.KeyCode ~= Enum.KeyCode.Unknown then
