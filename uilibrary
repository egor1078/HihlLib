function ThemeManager:GetColor(colorName)
    local theme = self.Themes[self.CurrentTheme] or self.Themes.Dark
    return theme[colorName] or Color3.new(1,1,1)
end

function ThemeManager:SetTheme(themeName)
    if not self.Themes[themeName] then return end
    self.CurrentTheme = themeName
    
    local animSettings = TweenInfo.new(0.5, Enum.EasingStyle.Quint, Enum.EasingDirection.Out)
    
    for obj, props in pairs(self.Objects) do
        local targetProps = {}
        for propName, colorName in pairs(props) do
            -- special case for TextColor3 active vs inactive
            if type(colorName) == "function" then
                targetProps[propName] = colorName()
            else
                targetProps[propName] = self:GetColor(colorName)
            end
        end
        if obj and obj.Parent then
            Utility:Tween(obj, animSettings, targetProps)
        else
            self.Objects[obj] = nil
        end
    end
end

function ThemeManager:Register(obj, props)
    self.Objects[obj] = props
    -- apply immediately
    for propName, colorName in pairs(props) do
        if type(colorName) == "function" then
            obj[propName] = colorName()
        else
            obj[propName] = self:GetColor(colorName)
        end
    end
end

